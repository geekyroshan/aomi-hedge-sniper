# ────────────────────────────────────────────────────────────────────────────
# hedge-sniper environment variables
# Copy to .env.local and fill in. Run `pnpm verify-env` to confirm.
# ────────────────────────────────────────────────────────────────────────────

# AOMI runtime — get a key from https://aomi.dev (dashboard) or DM the founder.
# Without this, the demo runs in MOCK MODE (clearly labelled in the UI).
AOMI_API_KEY=

# AOMI hosted runtime endpoint. Leave default unless self-hosting.
AOMI_BASE_URL=https://aomi.dev

# AOMI app/plugin handle to load into the agent. The runtime needs this to know
# which Rust plugins to expose. Use "polymarket" for the hosted polymarket plugin.
NEXT_PUBLIC_AOMI_APP=polymarket

# OpenAI API key — used by the correlation extractor in /api/hedge.
# Model: gpt-4o-mini (cheap; ~$0.001 per scan).
OPENAI_API_KEY=

# Polygon RPC for any direct CLOB calls / on-chain reads. Free tier from
# Alchemy/QuickNode/PublicNode is fine. Defaults to public RPC if unset.
POLYGON_RPC_URL=https://polygon-rpc.com

# Wallet private key for the demo trader. USE A FRESH WALLET — fund it with
# ~$60 USDC on Polygon. NEVER commit your real key. The agent signs through
# AOMI's Para AA flow; this is the EOA that owns the smart-wallet.
WALLET_PRIVATE_KEY=

# Optional: force-disable MOCK MODE even when AOMI_API_KEY is set (for testing).
# AOMI_FORCE_MOCK=1
